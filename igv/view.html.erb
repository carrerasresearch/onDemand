<div class="card">
  <div class="card-body text-center">
    <% if host && port && password %>
      <% 
        # Extract the VNC password from our combined string
        vnc_pass = password.to_s.split('|')[0]
        
        # Public domain and Proxy path to fix the DNS/WebSocket error you saw
        public_domain = "ood.services.carrerasresearch.org"
        proxy_path = "node/#{host}/#{port}/websockify"
        
        vnc_url = "/pun/sys/dashboard/noVNC-1.3.0/vnc.html?autoconnect=true&host=#{public_domain}&port=5560&path=#{proxy_path}&password=#{vnc_pass}&resize=remote&encrypt=true"
      %>

      <h4 class="text-success"><i class="fas fa-check-circle"></i> IGV Ready</h4>
      <p>Running on node <strong><%= host %></strong></p>

      <a href="<%= vnc_url %>" class="btn btn-primary btn-lg" target="_blank">
        <i class="fas fa-desktop"></i> Launch IGV Desktop
      </a>

      <div class="mt-3 small text-muted text-left">
        <details>
          <summary>Connection Debug</summary>
          <ul>
            <li><strong>Internal Node:</strong> <%= host %></li>
            <li><strong>Internal Port:</strong> <%= port %></li>
            <li><strong>Proxy Path:</strong> <code><%= proxy_path %></code></li>
          </ul>
        </details>
      </div>

    <% else %>
      <div class="alert alert-warning">
        <i class="fas fa-sync fa-spin"></i> Initializing connection...
      </div>
      <script>setTimeout(function(){ window.location.reload(); }, 3000);</script>
    <% end %>
  </div>
</div>
