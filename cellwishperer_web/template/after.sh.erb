# Wait for the Cellxgene server to start
echo "Waiting for Cellxgene server to open port ${port}..."
echo "TIMING - Starting wait at: $(date)"
# Increased timeout to 300 seconds (5 minutes)
if wait_until_port_used "${host}:${port}" 3600; then
  echo "Discovered Cellxgene server listening on port ${port}!"
  echo "TIMING - Wait ended at: $(date)"
else
  echo "Timed out waiting for Cellxgene server to open port ${port}!"
  echo "TIMING - Wait ended at: $(date)"
  pkill -P ${SCRIPT_PID}
  clean_up 1
fi
sleep 2
