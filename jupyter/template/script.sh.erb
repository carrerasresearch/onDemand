#!/usr/bin/env bash

# Benchmark info
echo "TIMING - Starting jupyter at: $(date)"

# Load the required environment
setup_env () {
  export JUPYTERLAB_IMAGE="/ijc/PUBLIC/DATA/images/jupyter-cellranger-gpu.sif"
  echo "hostname: $(hostname)"
  
  module purge
  module load singularity
  # We need a python to generate the secure cookie key
  module load Python/3.8.5-GCCcore-11.2.0

  <% if context.use_gpu == 'test-gpu' %>
  # Load the CUDA module only when GPU is requested in the form
  module load CUDA/12.3.1
  <% end %>
}

setup_env

# Setup workspace
workdir="${HOME}/jupyterlab_ood"
mkdir -p -m 700 "$workdir/run" "$workdir/tmp" "$workdir/R/user-libs"

# --- RESTORE OOD COOKIE LOGIC ---
export TMPDIR="$(mktemp -d)"
mkdir -p "$TMPDIR/jupyterlab-server"
python3 -c 'from uuid import uuid4; print(uuid4())' > "$TMPDIR/jupyterlab-server/secure-cookie-key"
chmod 0600 "$TMPDIR/jupyterlab-server/secure-cookie-key"

# --- SET ISOLATION VARIABLES ---
export SINGULARITYENV_PATH="/opt/conda/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
export SINGULARITYENV_PREPEND_PATH="/opt/conda/bin"
# Mask host .condarc and bind OOD's config/run dirs
export SINGULARITY_BINDPATH="/dev/null:${HOME}/.condarc,/ijc:/ijc,${workdir}/run:/run"

# Launch info
echo "Starting up JupyterLab server..."

SINGULARITY_GPU_FLAG=""
<% if context.use_gpu == 'test-gpu' %>
SINGULARITY_GPU_FLAG="--nv"
<% end %>

# --- LAUNCH COMMAND ---
set -x
singularity exec ${SINGULARITY_GPU_FLAG} --cleanenv \
  -B "${workdir}/R/user-libs:${workdir}/R/user-libs" \
  --env R_LIBS_USER="${workdir}/R/user-libs" \
  --env CONDA_ENVS_PATH="/opt/conda/envs,~/.conda/envs" \
  --env SHELL="/bin/bash" \
  "${JUPYTERLAB_IMAGE}" \
  /bin/bash --norc -c "
    source /opt/conda/etc/profile.d/conda.sh && \
    conda activate jlab-env && \
    jupyter lab --no-browser \
      --ip=0.0.0.0 \
      --port=${port} \
      --notebook-dir='${HOME}' \
      --config='${CONFIG_FILE}'
  "

echo 'Singularity has exited...'
