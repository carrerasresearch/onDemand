#!/usr/bin/env bash

source /etc/profile.d/lmod.sh

# Explicitly set the HOME variable at the beginning of the script to be safe.
# The `OOD_HOME` variable is provided by OnDemand for this purpose.
export HOME="${HOME}"

# Load the required environment
setup_env () {
  # Additional environment which could be moved into a module
  # Change these to suit
  export RSTUDIO_SERVER_IMAGE="/ijc/PUBLIC/DATA/images/tidyverse_3.21-R-4.5.1.sif"
  echo "hostname: `hostname`"
  module load singularity
  module load Python/3.8.5-GCCcore-11.2.0 
} 

setup_env

#
# Start RStudio Server
#

# PAM auth helper used by RStudio
export RSTUDIO_AUTH="${PWD}/bin/auth"

# Temporary directory to be populated with directories to bind-mount in the container
# where writable file systems are necessary. 
workdir="${HOME}/rstudio_server_tidyverse_321"
mkdir -p -m 700 $workdir

# Bindings
export SINGULARITY_BINDPATH="${workdir}/run:/run,${workdir}/database.conf:/etc/rstudio/database.conf,${workdir}/rsession.sh:/etc/rstudio/rsession.sh,${workdir}/var/lib/rstudio-server:/var/lib/rstudio-server,/ijc:/ijc,/opt/ohpc:/opt/ohpc,/opt/software:/opt/software,/usr/local/bin/lua:/usr/local/bin/lua"

mkdir -p -m 700 ${workdir}/run ${workdir}/tmp ${workdir}/var/lib/rstudio-server
cat > ${workdir}/database.conf <<END
provider=sqlite
directory=/var/lib/rstudio-server
END

# Generate an `rsession` wrapper script
export RSESSION_WRAPPER_FILE="${workdir}/rsession.sh"
(
umask 077
sed 's/^ \{2\}//' > "${RSESSION_WRAPPER_FILE}" << EOL
  #!/usr/bin/env bash

  # Log all output from this script
  export RSESSION_LOG_FILE="${workdir}/rsession.log"

  exec &>>"\${RSESSION_LOG_FILE}"

  # Add R's shared library path to LD_LIBRARY_PATH
  export LD_LIBRARY_PATH="/usr/local/lib/R/lib"
  
  export R_LIBS_USER=${workdir}/R/user-libs

  # Launch the original command
  echo "Launching rsession..."
  set -x
  exec /usr/lib/rstudio-server/bin/rsession --r-libs-user "${R_LIBS_USER}" "\${@}"
EOL
)
chmod 700 "${RSESSION_WRAPPER_FILE}"

# Do not suspend idle sessions.
# Alternative to setting session-timeout-minutes=0 in /etc/rstudio/rsession.conf
export SINGULARITYENV_RSTUDIO_SESSION_TIMEOUT=0
export SINGULARITYENV_USER=$(id -un)

# Set working directory to home directory
cd "${HOME}"

export TMPDIR="$(mktemp -d)"

mkdir -p "$TMPDIR/rstudio-server"
python3 -c 'from uuid import uuid4; print(uuid4())' > "$TMPDIR/rstudio-server/secure-cookie-key"
chmod 0600 "$TMPDIR/rstudio-server/secure-cookie-key"

set -x
# Launch the RStudio Server
echo "Starting up rserver..."


user=$(whoami)

echo "${user}"

singularity run -B "$TMPDIR:/tmp" "$RSTUDIO_SERVER_IMAGE" \
 /usr/lib/rstudio-server/bin/rserver \
 --www-port "${port}" \
 --auth-none=1 \
 --server-user="${user}" \
 --auth-pam-helper-path "${RSTUDIO_AUTH}" \
 --auth-encrypt-password 0 \
 --rsession-path "${RSESSION_WRAPPER_FILE}"

echo 'Singularity as exited...'
